VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Optional: only if you need auth base URL without a browser. In normal use the app uses the
# current page origin (so VITE_SITE_URL is usually not needed on Vercel).
# VITE_SITE_URL=https://your-app.vercel.app
#
# Require email before cart/checkout: Supabase → Authentication → Sign In / Providers → Email →
# enable "Confirm email".
#
# Transactional auth emails (signup confirmation, forgot password) are sent by Supabase, not this app.
# In Supabase Dashboard: Authentication → SMTP Settings → enable custom SMTP and use Brevo:
#   Host: smtp-relay.brevo.com   Port: 587 (TLS)   User: your Brevo account email   Password: Brevo SMTP key
# Verify the sender address (e.g. ecoshop.support@gmail.com) in Brevo (Senders) first, then set the
# same address as Sender email in Supabase. Add redirect URLs: .../login for each environment.
